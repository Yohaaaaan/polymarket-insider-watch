# Configuration template
# Copy this file to .env and fill in your actual values
# DO NOT commit .env file to version control

# =====================================================================
# Detection engine (TypeScript, src/) — Polymarket insider detector
# =====================================================================

# Alchemy Polygon API key for the real-time WebSocket listener.
# Leave empty to run in dry mode (no real-time listening).
ALCHEMY_API_KEY=

# PolygonScan (Etherscan-compatible) API key for wallet profiling.
# Leave empty to run profiling in mocked mode.
ETHERSCAN_API_KEY=

# Telegram bot token used to deliver alerts and the dashboard.
TELEGRAM_BOT_TOKEN=

# Target Telegram chat/channel ID for alerts.
TELEGRAM_CHAT_ID=

# =====================================================================
# Oracle Cloud Infrastructure — used only by the PHP provisioner (index.php)
# =====================================================================

# OCI Region (e.g., us-phoenix-1, eu-frankfurt-1, ap-tokyo-1)
OCI_REGION=us-phoenix-1

# OCI User OCID (starts with ocid1.user.oc1..)
OCI_USER_ID=ocid1.user.oc1..

# OCI Tenancy OCID (starts with ocid1.tenancy.oc1..)
OCI_TENANCY_ID=ocid1.tenancy.oc1..

# API Key Fingerprint (generated when creating API key)
OCI_KEY_FINGERPRINT=

# Path to your private key file (.pem) or URL to the key file
# Use absolute path: /home/user/.oci/oci_api_key.pem
# Or URL: https://example.com/path/to/key.pem
OCI_PRIVATE_KEY_FILENAME=

# Subnet OCID (get from browser dev tools during instance creation)
# Starts with ocid1.subnet.oc1..
OCI_SUBNET_ID=ocid1.subnet.oc1..

# Image OCID (get from browser dev tools during instance creation)
# Starts with ocid1.image.oc1..
OCI_IMAGE_ID=ocid1.image.oc1..

# SSH Public Key (contents of ~/.ssh/id_rsa.pub)
# NO newlines allowed! Single line only
OCI_SSH_PUBLIC_KEY="ssh-rsa AAAAB3NzaC1yc2EAAA... your-email@example.com"

# Optional: Instance Configuration
# Shape type - default is ARM Ampere A1
OCI_SHAPE=VM.Standard.A1.Flex

# For ARM A1: 1-4 OCPUs allowed (each OCPU = 6GB RAM)
# Possible combinations: 1/6, 2/12, 3/18, 4/24
OCI_OCPUS=4
OCI_MEMORY_IN_GBS=24

# For AMD x64 Always Free (if ARM not available):
# OCI_SHAPE=VM.Standard.E2.1.Micro
# OCI_OCPUS=1
# OCI_MEMORY_IN_GBS=1

# Maximum number of instances to create of this shape
OCI_MAX_INSTANCES=1

# Optional: Specific Availability Domain
# Leave empty to try all domains, or specify one like:
# OCI_AVAILABILITY_DOMAIN=FeVO:US-PHOENIX-1-AD-1
OCI_AVAILABILITY_DOMAIN=

# Optional: Instance display name prefix
OCI_DISPLAY_NAME=oracle-arm-instance